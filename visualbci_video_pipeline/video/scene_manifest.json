    {
      "id": "measurements",
      "title": "What EEG Measures",
      "start": 10.4,
      "end": 30.4,
      "duration": 20,
      "narration": "EEG measures tiny voltage changes at the scalp caused by large groups of neurons firing together. Electrodes do not read thoughts directly. They detect synchronized electrical activity.",
